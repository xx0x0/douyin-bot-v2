# Telegram Bot Token（从 @BotFather 申请）
BOT_TOKEN="把你的_BOT_TOKEN_粘到这里"

# 巴比馒头官网 Cookie（用于下载该平台视频，可选；不需要就留空字符串）
BADNEWS_COOKIES=""

# 允许私聊 bot 的 Telegram 用户 ID（多个用英文逗号分隔）
# 获取自己的 ID：在 Telegram 给 @userinfobot 发任意消息
ALLOWED_USER="123456789"

# 允许 bot 响应的群组 ID（多个用英文逗号分隔，群组 ID 通常以 -100 开头）
# 把 bot 加到群里后，发一条消息让 bot 看到，再查日志即可拿到群 ID
ALLOWED_GROUP="-1001234567890"
